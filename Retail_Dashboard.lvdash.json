            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "5b98e174",
      "displayName": "Count Total Sales",
      "queryLines": [
        "SELECT sum(total_price) AS Total_Sales, 3000000 AS Sales_Goal FROM databricks_simulated_retail_customer_data.v01.sales;"
      ]
    },
    {
      "name": "6dc36eef",
      "displayName": "Three Month Sales",
      "queryLines": [
        "SELECT customer_name, \r\n",
        "       total_price AS Total_Sales, \r\n",
        "       date_format(order_date, \"MM\") AS Month, \r\n",
        "       product_category \r\n",
        "FROM databricks_simulated_retail_customer_data.v01.sales \r\n",
        "WHERE order_date >= to_date('2019-08-01')\r\n",
        "AND order_date <=  to_date('2019-10-31');"
      ]
    },
